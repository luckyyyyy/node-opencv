{
  "name": "node-opencv",
  "version": "1.0.1",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "node-opencv",
    "target": {
      "defaults": false
    }
  },
  "files": [
    "*.node",
    "index.d.ts",
    "index.js"
  ],
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node demo/test.js"
  }
}
